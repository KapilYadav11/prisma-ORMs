generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  
}


model User {
  id         Int      @id @default(autoincrement())
  username   String   @unique
  password   String
  firstName  String
  lastName   String
  age        Int
  city       String
}


model Todo {
    id           Int  @default(autoincrement())  @id
    title        String
    description  String
    done         Boolean
    userId       Int
    
}